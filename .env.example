# ========================================
# MT-API Environment Configuration
# Copy this file to .env and update values
# ========================================

# === Database Configuration ===
DB_HOST=mt-api-db
DB_PORT=3306
DB_NAME=mt_api
DB_USER=mt_user
DB_PASS=secure_password_change_this
DB_EXPOSE_PORT=3307

# === Application ===
NODE_ENV=production
APP_PORT=8080

# === MikroTik Configuration ===
# Set these values based on your MikroTik router
MIKROTIK_HOST=192.168.10.1
MIKROTIK_PORT=8728
MIKROTIK_USER=bbapi
MIKROTIK_PASS=eepower
MIKROTIK_OS_VERSION=v7

# === Frontend Configuration ===
VITE_API_URL=http://localhost:3000/api

# === JWT & Security ===
JWT_SECRET=your_jwt_secret_key_change_this_to_something_long_and_random
JWT_EXPIRE=7d

# === Email Configuration (optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=MT-API System <noreply@mtapi.local>

# === Backup Configuration ===
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups/auto

# === Logging ===
LOG_LEVEL=info
LOG_PATH=./logs
